      <property name="styleSheet">
       <string notr="true">QTabWidget{
	background-color: white;
	color: #2d2d2d;
	border-radius: 10px;
}
QTabWidget::pane { 
    border: 1.2px solid #2980b9;
	border-bottom-left-radius: 10px;
	border-bottom-right-radius: 10px;
	border-top-right-radius: 10px;
    background-color: white;
    top: -1px; /* Ajuste para que no haya hueco entre pestaña y panel */
}
QWidget{
	background-color: transparent;
		border-bottom-left-radius: 10px;
	border-bottom-right-radius: 10px;
	border-top-right-radius: 10px;
}
QTabBar::tab {
    background: #2980b9;
    color: white;
    padding: 8px 12px;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    margin-right: 1px;
}

/* Cuando pasas el mouse por encima */
QTabBar::tab:hover {
    background: #0D47A1;
}

/* Cuando la pestaña está seleccionada */
QTabBar::tab:selected {
    background: #FFFFFF;
    color: #2980b9;
	border: 1.2px solid #2980b9;
}</string>
